{
  "name": "call_center",
  "title": "Call Center",
  "description": "Omnichannel call center workspace with queues, agents, tickets, call logs, SLA tracking, and operations reporting.",
  "version": "1.1.0",
  "author": "SBC Team",
  "category": "communication",
  "depends": ["base", "crm"],
  "optional_depends": [],
  "conflicts": [],
  "permissions": [
    { "key": "call_center.view", "label": "View call center records" },
    { "key": "call_center.dashboard.view", "label": "View the call center dashboard" },
    { "key": "call_center.queue.manage", "label": "Manage queues" },
    { "key": "call_center.agent.view", "label": "View agents" },
    { "key": "call_center.agent.manage", "label": "Manage agents" },
    { "key": "call_center.ticket.create", "label": "Create tickets" },
    { "key": "call_center.ticket.update", "label": "Update tickets" },
    { "key": "call_center.ticket.assign", "label": "Assign tickets" },
    { "key": "call_center.ticket.close", "label": "Close tickets" },
    { "key": "call_center.call.log", "label": "Log calls" },
    { "key": "call_center.report.view", "label": "View call center reports" }
  ],
  "menus": [
    {
      "key": "call_center.root",
      "label": "Call Center",
      "icon": "Phone",
      "order": 25,
      "permission": "call_center.view",
      "children": [
        { "key": "call_center.overview", "label": "Overview", "icon": "LayoutDashboard", "href": "/call-center", "order": 1, "permission": "call_center.dashboard.view" },
        { "key": "call_center.queues", "label": "Queues", "icon": "FolderOpen", "href": "/call-center/queues", "order": 2, "permission": "call_center.queue.manage" },
        { "key": "call_center.agents", "label": "Agents", "icon": "Users", "href": "/call-center/agents", "order": 3, "permission": "call_center.agent.view" },
        { "key": "call_center.tickets", "label": "Tickets", "icon": "ScrollText", "href": "/call-center/tickets", "order": 4, "permission": "call_center.view" },
        { "key": "call_center.calls", "label": "Calls", "icon": "Phone", "href": "/call-center/calls", "order": 5, "permission": "call_center.call.log" },
        { "key": "call_center.reports", "label": "Reports", "icon": "LayoutDashboard", "href": "/call-center/reports", "order": 6, "permission": "call_center.report.view" }
      ]
    }
  ],
  "routes": [
    { "path": "/call-center", "handler": "@call_center/pages/overview-page", "type": "page", "meta": { "permission": "call_center.dashboard.view" } },
    { "path": "/call-center/queues", "handler": "@call_center/pages/queues-page", "type": "page", "meta": { "permission": "call_center.queue.manage" } },
    { "path": "/call-center/agents", "handler": "@call_center/pages/agents-page", "type": "page", "meta": { "permission": "call_center.agent.view" } },
    { "path": "/call-center/tickets", "handler": "@call_center/pages/tickets-page", "type": "page", "meta": { "permission": "call_center.view" } },
    { "path": "/call-center/calls", "handler": "@call_center/pages/calls-page", "type": "page", "meta": { "permission": "call_center.call.log" } },
    { "path": "/call-center/reports", "handler": "@call_center/pages/reports-page", "type": "page", "meta": { "permission": "call_center.report.view" } }
  ],
  "settings": [
    {
      "key": "call_center.default_queue",
      "label": "Default Queue",
      "type": "text",
      "scope": "tenant",
      "default": "general"
    },
    {
      "key": "call_center.default_sla_minutes",
      "label": "Default SLA (minutes)",
      "type": "number",
      "scope": "tenant",
      "default": 60
    },
    {
      "key": "call_center.recordings_enabled",
      "label": "Enable Call Recordings",
      "type": "boolean",
      "scope": "tenant",
      "default": false
    },
    {
      "key": "call_center.dashboard_refresh_seconds",
      "label": "Dashboard Refresh Interval (seconds)",
      "type": "number",
      "scope": "tenant",
      "default": 30
    }
  ],
  "events": {
    "emits": [
      "call_center.queue.created",
      "call_center.ticket.created",
      "call_center.ticket.assigned",
      "call_center.ticket.closed",
      "call_center.call.logged"
    ],
    "listens": [
      "crm.customer.created"
    ]
  },
  "auto_install": false,
  "installable": true,
  "application": true
}
