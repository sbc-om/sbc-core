# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sbc:sbc_secret@localhost:5432/sbc_core"
DATABASE_POOL_MAX=10

# ─── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-minimum-32-characters-long"
AUTH_TOKEN_EXPIRY="7d"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SBC Core"
NODE_ENV="development"

# ─── Storage (MinIO / S3-compatible) ──────────────────────────────────────────
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="sbc-uploads"
STORAGE_REGION="us-east-1"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@sbc.local"

# ─── AI (Optional) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
