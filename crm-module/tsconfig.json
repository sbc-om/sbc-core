{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target":         "ES2022",
    "module":         "NodeNext",
    "moduleResolution": "NodeNext",
    "strict":         true,
    "noEmit":         true,
    "outDir":         "dist"
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
